{
  "name": "daisyreach-desktop",
  "version": "0.1.0",
  "description": "DaisyReach Desktop — local business discovery & outreach",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:main": "node build.mjs",
    "build:all": "node build.mjs && vite build",
    "electron:dev": "concurrently -k \"vite\" \"node build.mjs --watch\" \"sleep 2 && DAISYREACH_PATH=$HOME/projects/DaisyReach NODE_ENV=development electron .\"",
    "electron:build": "node build.mjs && vite build && electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "keywords": [],
  "author": "DaisyReach",
  "license": "UNLICENSED",
  "private": true
}
